---
import type { CollectionEntry } from "astro:content";
import { FaArrowRight } from "react-icons/fa";
import PostCard from "./PostCard.astro";
import PostSmall from "./PostSmall.astro";
type Writing = CollectionEntry<"writings">;

interface Props {
    featured: Writing[];
    recent: Writing[];
}
const { featured, recent } = Astro.props;

// Tailwind needs full literal class strings at build time, so map
// item counts to complete class strings rather than interpolating.
const gridColsMap: Record<number, string> = {
    0: "hidden",
    1: "grid-cols-1",
    2: "grid-cols-1 sm:grid-cols-2",
    3: "grid-cols-1 sm:grid-cols-3",
};

const featuredCols = gridColsMap[featured.length] ?? "grid-cols-1";
const recentCols = gridColsMap[recent.length] ?? "grid-cols-1";
---

<section>
    <div class="flex justify-between items-baseline mb-5">
        <span
            class="font-mono text-xs uppercase tracking-widest text-neutral-600 dark:text-neutral-200"
            >Writings</span
        >
        <a href="/writings" class="font-mono text-xs text-purple-700 flex gap-2"
            >all writings <FaArrowRight />
        </a>
    </div>

    <div
        class={`grid ${featuredCols} gap-px bg-neutral-200 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-800`}
    >
        {featured.map((post) => <PostCard post={post} />)}
    </div>

    <div
        class={`grid ${recentCols} gap-px bg-neutral-200 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-800 border-t-0`}
    >
        {recent.map((post) => <PostSmall post={post} />)}
    </div>
</section>