---
import type { Link } from "../../data/links";

interface Props {
    link: Link;
}

const { link } = Astro.props;
---

<li>
    <a
        href={link.url}
        class="hover:bg-neutral-50/50 dark:hover:bg-neutral-900/40 transition-colors block py-3"
    >
        <h3 class="text-xl">{link.title}</h3>
        {
            link.author && (
                <p class="ml-5 text-zinc-400 dark:text-zinc-500">
                    {" "}
                    by {link.author}
                </p>
            )
        }

        {
            link.description && (
                <p class="ml-3 text-zinc-500 dark:text-zinc-600">
                    {link.description}
                </p>
            )
        }
    </a>
</li>
