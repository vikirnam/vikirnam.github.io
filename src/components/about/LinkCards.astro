---
import { FaMastodon } from "react-icons/fa";
import { FiGithub, FiLinkedin, FiMail, FiFileText } from "react-icons/fi";

const links = [
    { icon: FiGithub, label: "github", href: "https://github.com/vikirnam" },
    {
        icon: FaMastodon,
        label: "hachyderm",
        href: "https://hachyderm.io/@faultypointer",
    },
    {
        icon: FiLinkedin,
        label: "linkedin",
        href: "https://linkedin.com/in/sudesh0subedi",
    },
    { icon: FiMail, label: "email", href: "mailto:sudeshsubedi123@gmail.com" },
    { icon: FiFileText, label: "résumé.pdf", href: "/resume/main.pdf" },
];
---

<p class="font-mono text-[11px] tracking-widest uppercase text-zinc-400 mb-5">
    links and socials
</p>

<div class="flex flex-col gap-1 mt-5">
    {
        links.map(({ icon: Icon, label, href }) => (
            <a
                href={href}
                class="flex items-center gap-2 px-2.5 py-1.5 font-mono text-xs text-zinc-400 rounded-sm border border-transparent hover:border-zinc-700 hover:text-zinc-100 transition-colors"
            >
                <Icon className="text-purple-700 shrink-0" size={15} />
                {label}
            </a>
        ))
    }
</div>
