---
const rows = [
    { key: "Name", val: "Sudesh Subedi" },
    { key: "Role", val: "Computer Engineer" },
    { key: "Focus", val: "Operating Systems, Rust" },
    { key: "Based", val: "Kathmandu" },
    { key: "Status", val: "open to work", green: true },
];
---

<div
    class="rounded-sm border border-zinc-200 dark:border-zinc-800 overflow-hidden"
>
    <div
        class="flex items-center gap-1.5 px-3 py-2 bg-zinc-100 dark:bg-zinc-900 border-b border-zinc-200 dark:border-zinc-800"
    >
        <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-green-500"></span>
        <span class="font-mono text-[11px] text-zinc-400 ml-1">whoami.sh</span>
    </div>

    <div class="p-5 font-mono text-xs leading-[1.9]">
        {
            rows.map((row) => (
                <div class="flex">
                    <span class="text-purple-700 w-18 shrink-0">{row.key}</span>
                    <span class="text-zinc-400 mr-2">:</span>
                    <span
                        class={`${row.green ? "text-green-600 dark:text-green-400" : "text-zinc-900 dark:text-zinc-100"}`}
                    >
                        {row.val}
                    </span>
                </div>
            ))
        }

        <div
            class="mt-3 pt-3 border-t border-zinc-200 dark:border-zinc-800 text-[11px] text-zinc-400"
        >
            // actively seeking systems roles<span
                class="inline-block w-1.75 h-3.25 bg-purple-700 align-[-2px] ml-1 animate-[blink_1.1s_step-end_infinite]"
            ></span>
        </div>
    </div>
</div>
