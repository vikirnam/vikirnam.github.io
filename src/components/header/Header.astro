---
// import Logo from "./Logo.astro";
import NavItem from "./NavItem.astro";
import ThemeToggle from "./ThemeToggle.astro";
---

<header
    class="border-b border-neutral-200 dark:border-neutral-800 mb-14 sticky top-0 z-50 bg-white/80 dark:bg-neutral-950/80 backdrop-blur-sm"
>
    <nav class="flex justify-between items-center py-4 max-w-4xl mx-auto px-6">
        <a href="/" class="text-sm font-medium tracking-tight">
            Vikirna
            <span class="w-1.5 h-1.5 rounded-full bg-purple-700 inline-block ml-0.5"
            ></span>
        </a>

        <!-- Desktop nav -->
        <ul class="hidden md:flex gap-8 list-none">
            <NavItem url="/" content="home" />
            <NavItem url="/projects" content="projects" />
            <NavItem url="/writings" content="writings" />
            <NavItem url="/about" content="about" />
        </ul>

        <!-- Right side: theme toggle + hamburger -->
        <div class="flex items-center gap-4">
            <ThemeToggle />

            <button
                id="menu-toggle"
                type="button"
                aria-label="Toggle menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
                class="md:hidden inline-flex items-center justify-center w-8 h-8 -mr-1"
            >
                <!-- hamburger icon -->
                <svg
                    id="icon-open"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
                <!-- close icon -->
                <svg
                    id="icon-close"
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5 hidden"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div
        id="mobile-menu"
        class="md:hidden hidden flex-col border-t border-neutral-200 dark:border-neutral-800 px-6 py-4"
    >
        <ul class="flex flex-col gap-4 list-none">
            <NavItem url="/" content="home" />
            <NavItem url="/projects" content="projects" />
            <NavItem url="/writings" content="writings" />
            <NavItem url="/about" content="about" />
        </ul>
    </div>
</header>

<script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    toggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.contains("flex");

        menu?.classList.toggle("hidden");
        menu?.classList.toggle("flex");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");

        toggle.setAttribute("aria-expanded", String(!isOpen));
    });
</script>