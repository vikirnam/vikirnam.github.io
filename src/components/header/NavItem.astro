---
const { url, content } = Astro.props;
const text_color_style =
    url === Astro.url.pathname
        ? "text-neutral-900 dark:text-neutral-50"
        : "text-neutral-500 dark:text-neutral-400";
---

<li>
    <a
        href={url}
        class={`font-mono text-sm ${text_color_style} hover:text-neutral-900 dark:hover:text-neutral-200 transition-colors`}
        >{content}</a
    >
</li>
