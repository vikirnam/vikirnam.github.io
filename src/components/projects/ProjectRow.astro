---
// src/components/projects/ProjectRow.astro
import type { Project } from "../../data/project";

interface Props {
    project: Project;
}
const { project } = Astro.props;
---

<div
    class="border-b border-neutral-100 dark:border-neutral-800/60 py-5 justify-between
         items-start gap-4 hover:bg-neutral-50/50 dark:hover:bg-neutral-900/40 transition-colors block px-2"
>
    <div
        class="flex flex-col md:flex-row md:items-baseline justify-between gap-2"
    >
        <h3
            class="text-base font-medium tracking-tight text-neutral-800 dark:text-neutral-200"
        >
            {project.name}
            {
                project.title && (
                    <span class="text-neutral-400 font-normal text-sm">
                        : {project.title}
                    </span>
                )
            }
        </h3>

        <ol
            class="flex gap-1.5 font-mono text-[10px] text-neutral-400 dark:text-neutral-500"
        >
            {
                project.stack.map((tech) => (
                    <li class="border border-neutral-200 dark:border-neutral-700 px-1 rounded-sm">
                        {tech}
                    </li>
                ))
            }
        </ol>
    </div>

    <p
        class="text-xs text-neutral-500 dark:text-neutral-400 leading-relaxed mt-1.5"
    >
        {project.description}
    </p>
</div>
