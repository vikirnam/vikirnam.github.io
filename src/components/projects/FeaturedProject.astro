---
// src/components/projects/FeaturedProject.astro
import type { Project } from "../../data/project";

interface Props {
    project: Project;
}
const { project } = Astro.props;
---

<div
    class="border border-purple-200 dark:border-purple-900 bg-purple-50/30 dark:bg-purple-950/10 rounded-md p-8
           flex flex-col gap-4 mb-8 hover:bg-purple-50/50 dark:hover:bg-purple-950/20 transition-all shadow-sm"
>
    <ol
        class="flex flex-wrap gap-2 font-mono text-xs text-purple-700 dark:text-purple-400"
    >
        {
            project.stack.map((tech) => (
                <li class="border border-purple-300 dark:border-purple-800 bg-purple-100/50 dark:bg-purple-900/30 px-1.5 py-0.5 rounded-sm">
                    {tech}
                </li>
            ))
        }
    </ol>

    <h3
        class="text-2xl font-semibold tracking-tight leading-snug text-neutral-900 dark:text-neutral-50"
    >
        {project.name}
        {
            project.title && (
                <span class="text-neutral-500 font-normal">
                    : {project.title}
                </span>
            )
        }
    </h3>

    <p
        class="text-sm text-neutral-600 dark:text-neutral-300 leading-relaxed max-w-2xl"
    >
        {project.description}
    </p>
</div>
