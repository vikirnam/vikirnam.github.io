---
import type { CollectionEntry } from "astro:content";
type Writing = CollectionEntry<"writings">;

interface Props {
    post: Writing;
}
const { post } = Astro.props;
const { title, date, tags } = post.data;
---

<a
    href={`/writings/${post.id}`}
    class="post-row grid grid-cols-[64px_1fr_80px] gap-5 items-baseline py-4 border-b border-neutral-200 dark:border-neutral-800 hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-colors"
    data-tags={tags}
>
    <span class="font-mono text-xs text-neutral-400 dark:text-neutral-300">
        {date.toLocaleDateString()}
    </span>
    <div>
        <span class="text-sm font-medium tracking-tight block mb-0.5">
            {title}
        </span>
        <ol
            class="flex gap-2 font-mono text-xs text-neutral-400 dark:text-neutral-300"
        >
            {tags.map((tag) => <li>{tag}</li>)}
        </ol>
    </div>
</a>
