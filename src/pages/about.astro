---
import TerminalCard from "@components/about/TerminalCard.astro";
import InterestGrid from "@components/about/InterestGrid.astro";
// import Timeline from "@components/about/Timeline.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import LinkCards from "@components/about/LinkCards.astro";
---

<BaseLayout pageTitle="About Me">
    <div
        class="py-8 md:py-12 grid grid-cols-1 lg:grid-cols-[320px_1fr] gap-10 lg:gap-16 items-start"
    >
        <aside class="lg:sticky lg:top-8 lg:overflow-y-hidden order-2 lg:order-1">
            <TerminalCard />

            <hr class="divider" />

            <LinkCards />
            <hr class="divider" />

            <InterestGrid />
        </aside>

        <main class="order-1 lg:order-2">
            <p class="eyebrow">about</p>
            <h1 class="text-3xl sm:text-4xl font-medium tracking-tight leading-tight mb-7">
                I build things close<br /> to metal.<br />
            </h1>

            <div class="prose-block text-balance">
                <p>
                    I'm a Computer Engineering graduate with a strong interest
                    in <strong
                        >low level systems, particularly operating system
                        internals, algorithms and performance optimizations</strong
                    >. I've build a <strong
                        >decentralized and federated microblogging platform with
                        latex support for scientific communication</strong
                    > as part of my minor project during my computer engineering years.
                    I have also build an <strong
                        >overlay filesystem implementation for microkernel based
                        operating system</strong
                    > for the final year project.
                </p>

                <p>
                    <!-- TODO: links to projects mentioned 
                    (writeups if I ever write one otherwise link to repo)
                    -->
                    Although my interest mainly lie somewhat close to hardware, I
                    do find myself enjoying the comforts of abstractions available
                    when building web apps or programming <strong
                        >a chess engine</strong
                    > or doing silly little projects like <strong
                        >a CLI app for learning japanese</strong
                    >.
                </p>
            </div>

            <!-- TODO: Add timeline
            <hr class="divider" />

            <Timeline /> -->
        </main>
    </div>
</BaseLayout>