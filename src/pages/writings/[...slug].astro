---
import PostHeader from "@components/writings/PostHeader.astro";
import RelatedPosts from "@components/writings/RelatedPosts.astro";
import TableOfContents from "@components/writings/TableOfContents.astro";
import PostLayout from "@layouts/PostLayout.astro";
import { render } from "astro:content";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    function commonTagScore(aTags: String[], bTags: String[]) {
        const aSet = new Set(aTags);
        const bSet = new Set(bTags);

        return aSet.intersection(bSet).size / aSet.size;
    }

    const posts = await getCollection("writings", ({ data }) => !data.draft);
    return posts.map((post) => {
        const relatedPosts = posts
            .filter((other) => other.id !== post.id)
            .map((other) => {
                const score = commonTagScore(post.data.tags, other.data.tags);

                return { post: other, score };
            })
            .filter((r) => r.score > 0)
            .sort((a, b) => b.score - a.score)
            .map((p) => p.post);

        return {
            params: { slug: post.id },
            props: { post, relatedPosts },
        };
    });
}

const { post, relatedPosts } = Astro.props;
const { Content, headings } = await render(post);

---
<PostLayout title={post.data.title}>
    <PostHeader slot="header" post={post} />

    <article slot="article">
        <div class="prose prose-neutral max-w-none
            prose-headings:font-medium prose-headings:tracking-tight prose-headings:text-neutral-900 dark:prose-headings:text-neutral-50
            prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl
            prose-p:text-neutral-600 dark:prose-p:text-neutral-300 prose-p:leading-relaxed
            prose-a:text-[#c81232] prose-a:no-underline hover:prose-a:underline
            prose-code:font-mono prose-code:text-xs
            prose-code:text-neutral-800 dark:prose-code:text-neutral-200
            prose-code:px-1.5 prose-code:rounded-sm prose-code:before:content-none
            prose-code:after:content-none
            prose-code:text-balance
            prose-pre:overflow-x-auto prose-pre:-mx-4 sm:prose-pre:mx-0 prose-pre:rounded-none sm:prose-pre:rounded-md
            prose-img:rounded-md
            prose-strong:text-neutral-900 dark:prose-strong:text-neutral-50 prose-strong:font-medium
            prose-li:text-neutral-600 dark:prose-li:text-neutral-300"
        >
            <Content />
        </div>
    </article>

    <TableOfContents slot="toc" headings={headings} />
    <RelatedPosts slot="related" posts={relatedPosts} />
</PostLayout>

<style is:global>
    .data-footnote-backref {
        display: none;
    }
</style>
